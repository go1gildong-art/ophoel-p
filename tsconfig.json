{
  "compilerOptions": {
    "target": "ES2019",
    "module": "CommonJS",
    "lib": [
      "ES2019"
    ],
    "outDir": "out",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "types": [
      "node",
      "vscode"
    ],
    "allowJs": true,
    "noUncheckedIndexedAccess": true,

    "paths": {
      "@utils/*": ["./src/utils/*"]
    }
  },
  "include": [
    "./src"
, "src/test-resources/interpret-cases/units/.test_block-expr.cts"  ],
  "exclude": [
    "./node_modules",
    "./src/test",
    "./src/compiler-old"
  ],
}